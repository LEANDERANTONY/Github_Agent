# Optional environment-variable configuration reference.
# The app also supports local secret files in the repo root, but environment
# variables are the cleaner path for deployment and shared development setups.

OPENAI_API_KEY=
OPENAI_REPO_MODEL=gpt-5-mini
OPENAI_PORTFOLIO_MODEL=gpt-5.4
OPENAI_FINAL_REPORT_MODEL=gpt-5.4

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8501
GITHUB_OAUTH_SCOPE=read:user user:email
