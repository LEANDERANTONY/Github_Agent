# Copy this file to `.streamlit/secrets.toml` for local Streamlit secrets,
# or paste the same keys into the Streamlit Community Cloud secrets manager.

OPENAI_API_KEY = ""
OPENAI_REPO_MODEL = "gpt-5-mini"
OPENAI_PORTFOLIO_MODEL = "gpt-5.4"
OPENAI_FINAL_REPORT_MODEL = "gpt-5.4"

GITHUB_OAUTH_CLIENT_ID = ""
GITHUB_OAUTH_CLIENT_SECRET = ""
GITHUB_OAUTH_REDIRECT_URI = "http://localhost:8501"
GITHUB_OAUTH_SCOPE = "read:user user:email"
